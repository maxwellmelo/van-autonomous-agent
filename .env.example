# Van Autonomous Agent — Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
#
# NOTE: AI provider keys, model config, memory paths, messaging,
# and daemon settings are ALL configured in openclaw.config.yaml.
# This file only contains Van-specific runtime overrides.

# ============================================================
# OpenClaw Connection
# ============================================================

# OpenClaw daemon URL. Default OpenClaw port: 18789.
# Only change this if you modified the port in openclaw.config.yaml.
# OPENCLAW_URL=http://localhost:18789

# ============================================================
# Cognitive Loop
# ============================================================
#
# Van operates a continuous cognitive loop called OODA+:
#   OBSERVE → ORIENT → DECIDE → ACT → REFLECT → EVOLVE
#
# Each "cycle" is one full iteration of this loop:
#   1. OBSERVE  — Reads memory, assesses active goals, checks environment
#   2. ORIENT   — Synthesizes the situation, prioritizes goals, detects risks
#   3. DECIDE   — Selects the priority goal, creates an action plan
#   4. ACT      — Executes actions via OpenClaw (shell, browser, APIs)
#   5. REFLECT  — Analyzes results, extracts learnings, updates memory
#   6. EVOLVE   — Improves capabilities, adjusts strategies, closes goals
#
# The interval between cycles controls the agent's operating speed.

# Milliseconds between cognitive cycles.
# Lower = faster iteration (more aggressive), higher = less resource usage.
# Examples: 1000 (1s, very fast), 5000 (5s, default), 30000 (30s, conservative)
# CYCLE_INTERVAL_MS=5000

# Maximum number of cycles before stopping automatically.
# Leave empty/commented for unlimited operation (production mode).
# Useful for testing: 1 = single cycle, 5 = short test run.
# MAX_CYCLES=
